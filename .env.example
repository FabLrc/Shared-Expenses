# Copy this file to .env.local and fill in the values

# Vercel Postgres (set via `vercel env pull .env.local` after project setup)
POSTGRES_PRISMA_URL="postgresql://user:password@host/database?pgbouncer=true&connect_timeout=15"
POSTGRES_URL_NON_POOLING="postgresql://user:password@host/database"

# NextAuth
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=""
NEXTAUTH_URL="http://localhost:3000"

# Google OAuth
# Create at: https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Discord OAuth
# Create at: https://discord.com/developers/applications
# Redirect URI: http://localhost:3000/api/auth/callback/discord
DISCORD_CLIENT_ID=""
DISCORD_CLIENT_SECRET=""
