# ─── Vercel Prisma Postgres ──────────────────────────────────────────────────
# Ces variables sont ajoutées automatiquement par Vercel lors de l'intégration.
#
# DATABASE_URL   → connexion PostgreSQL directe (migrations + runtime local)
# POSTGRES_URL   → identique à DATABASE_URL (alias Vercel)
# PRISMA_DATABASE_URL → URL prisma:// pour Prisma Accelerate (optionnel, production)
#
DATABASE_URL="postgresql://user:password@host:5432/database?sslmode=require"
POSTGRES_URL="postgresql://user:password@host:5432/database?sslmode=require"
PRISMA_DATABASE_URL="prisma://accelerate.prisma-data.net/?api_key=..."

# ─── NextAuth ─────────────────────────────────────────────────────────────────
# Générer avec : openssl rand -base64 32
NEXTAUTH_SECRET=""
NEXTAUTH_URL="http://localhost:3000"

# ─── Google OAuth ─────────────────────────────────────────────────────────────
# Créer sur : https://console.cloud.google.com/apis/credentials
# Redirect URI autorisée : https://votre-domaine.vercel.app/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ─── Discord OAuth ────────────────────────────────────────────────────────────
# Créer sur : https://discord.com/developers/applications
# Redirect URI : https://votre-domaine.vercel.app/api/auth/callback/discord
DISCORD_CLIENT_ID=""
DISCORD_CLIENT_SECRET=""
